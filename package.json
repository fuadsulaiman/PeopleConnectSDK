{
  "name": "@peopleconnect/sdk",
  "version": "1.0.0",
  "description": "Official TypeScript SDK for the PeopleConnect API",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.mjs",
      "require": "./dist/types.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/types.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts src/types.ts --format cjs,esm --dts --watch",
    "lint": "eslint src/",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "peopleconnect",
    "sdk",
    "api",
    "chat",
    "messaging",
    "realtime",
    "typescript"
  ],
  "author": "PeopleConnect",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/peopleconnect/sdk.git"
  },
  "bugs": {
    "url": "https://github.com/peopleconnect/sdk/issues"
  },
  "homepage": "https://github.com/peopleconnect/sdk#readme",
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
